<html>

<style>
    .catalog {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    table {
        border: 2px solid;
    }

    table, th, td {
        border: 1px solid;
        border-collapse: collapse;
        padding: 5px;
    }

    th {
        background-color: darkgoldenrod;
        border-color: black;
        color: white;
    }

    tr.data {
        cursor: pointer;
    }

    tr:nth-child(even).data {
        background-color: blanchedalmond;
    }

    tr:hover.data {
        background-color: khaki;
    }
</style>

<head>
    <title>Warehouse Worker</title>
</head>

<body>
    <h2>Warehouse Worker View</h2>
    <a href="/">Home</a><br><br>

    <% if (typeof order === 'undefined') { %>

        <!-- ORDER LIST -->
        <h3>Orders to Process: <%= orders.length %></h3>

        <% if (orders.length === 0) { %>
            <p>No orders to process right now.</p>
        <% } else { %>
            <table>
                <tr>
                    <th>Order ID</th>
                    <th>Date</th>
                    <th>Customer</th>
                    <th>Total</th>
                    <th>Action</th>
                </tr>
                <% orders.forEach(function(o) { %>
                <tr class="data">
                    <td><%= o.orderid %></td>
                    <td><%= o.date %></td>
                    <td><%= o.custName %></td>
                    <td>$<%= o.subtotal %></td>
                    <td>
                        <a href="/warehouse/order/<%= o.orderid %>">
                            <button>Start Packing</button>
                        </a>
                    </td>
                </tr>
                <% }); %>
            </table>
        <% } %>

    <% } else { %>

        <!-- PACKING LIST -->
        <h3>Packing List — Order #<%= order.orderID %></h3>
        <p>Customer: <%= order.custName %></p>
        <p>Ship to: <%= order.custAddress %>, <%= order.custCity %>, <%= order.custState %> <%= order.custZip %></p>

        <form method="POST" action="/warehouse/order/<%= order.orderID %>/ship">
            <table>
                <tr>
                    <th>Part Number</th>
                    <th>Description</th>
                    <th>Quantity</th>
                    <th>Gathered?</th>
                </tr>
                <% items.forEach(function(item) { %>
                <tr>
                    <td><%= item.partNumber %></td>
                    <td><%= item.description %></td>
                    <td><%= item.quantity %></td>
                    <td>
                        <input type="checkbox" name="gathered_<%= item.partNumber %>" required>
                    </td>
                </tr>
                <% }); %>
            </table>

            <br>
            <button type="button" onclick="window.print()">Print Packing List / Invoice</button><br><br>

            <label>
                <input type="checkbox" name="invoiceAdded" required>
                Invoice has been printed and added
            </label><br>

            <label>
                <input type="checkbox" name="labelAdded" required>
                Shipping label has been printed and added
            </label><br><br>

            <button type="submit">Confirm Shipped</button>
        </form>

        <br>
        <a href="/warehouse">Back to Order List</a>

    <% } %>

</body>
</html>
