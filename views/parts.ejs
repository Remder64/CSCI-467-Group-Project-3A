<html>

<style>
        body {
            background-color: #CBC093;
            font-family: sans-serif;
            margin: 0;
            padding: 20px;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
        }

        .page_header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 20px;
            margin-bottom: 24px;
        }

        .brand_text {
            display: flex;
            flex-direction: column;
        }

        .cart {
            display: flex;
            gap: 18px;
            align-items: center;
        }

        .cart a {
            color: #1d1d1d;
            font-weight: 600;
            padding: 8px 12px;
            border-radius: 6px;
        }

        .cart a:hover {
            background-color: #565039;
        }

        h1 {
            text-align: center;
            font-size: 3rem;
            margin-top: 0;
            margin-bottom: 20px;
        }

        #search {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 24px;
        }

        #search input {
            width: 100%;
            max-width: 500px;
            padding: 15px;
            font-size: 1rem;
            border: #f8f4e8;
            border-radius: 8px;
        }

        #search button {
            padding: 12px 18px;
            font-size: 1rem;
            border: none;
            border-radius: 8px;
            background-color: #CFA902;
            color: white;
            cursor: pointer;
        }

        #search button:hover {
            background-color: #b38a01;
        }

        #add_to_cart {
            padding: 5px;
            cursor: pointer;
        }

        .catalog {
            overflow-x: auto;
        }

        table {
            border: 2px solid;
            border-radius: 8px;
            width: 100%;
        }

        table, th, td {
            border: 1px solid;
            border-collapse: collapse;
            padding: 8px;
        }

        th {
            background-color: #CFA902;
            border-color: #191500;
            color: #FFFAE6;
            text-align: center;
        }

        tr:nth-child(even).data {
            background-color: #FFFCEE;
        }

        tr:nth-child(odd).data {
            background-color: #FFF0B1;
        }

        tr:hover.data {
            background-color: #B2A671;
        }

</style>

<head>
    <title>Part List</title>
</head>

<body>
    <header class="page_header">
        <div class="brand_text">
                <h2>MANual Auto Parts</h2>
                <label>With Quality Parts for a Quality Customer</label>
        </div>

        <nav class="cart">
            <a href="/">Home</a>
            <a href="/cart">Cart (<%= partsInCart %>)</a>
        </nav>
    </header>

    <h1>Part Catalog</h1>

    <form id="search" method="POST" action="/getParts/search">
        <input type="text" name="search" placeholder="What are you looking for today?" />
        <button type="submit">Search</button>
    </form>

    <div class="catalog">
        <table>
            <tr>
                <th>Picture</th>
                <th>Name</th>
                <th>Part Number</th>
                <th>Weight</th>
                <th>Price</th>
                <th>Cart</th>
            </tr>
            <% for (part in all) { %>
            <tr class="data">
                <td><img src="<%= all[part].pictureURL %>"></td>
                <td><%= all[part].description %></td>
                <td><%= all[part].number %></td>
                <td><%= all[part].weight %> lbs</td>
                <td>$<%= all[part].price %></td>
                <td>
                    <form action="/cart/add/<%= all[part].number %>" method="POST">
                        <input type="text" name="quantity" value=""><br><br>
                        <input type="submit" value="Add to cart">
                    </form>
                </td>
            </tr>
            <% }; %>
        </table>
    </div>
</body>

</html>
